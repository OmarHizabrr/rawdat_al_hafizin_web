rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return firestore.get(/databases/(default)/documents/users/$(uid));
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/(default)/documents/users/$(request.auth.uid))
        && userDoc(request.auth.uid).data.role == 'admin';
    }

    // صور الملف الشخصي: المستخدم يرفع لمجلده، أو الأدمن لأي userId
    match /users_profile_media/{userId}/{fileName} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*')
        && (request.auth.uid == userId || isAdmin());
      allow delete: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }
  }
}
